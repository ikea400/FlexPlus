# ─── ETS Portal credentials ───────────────────────────────────────────────
# ETS email address used to authenticate against the ADFS SSO portal
ETS_EMAIL=your_ets_email

# ETS portal password
ETS_PASSWORD=your_ets_password

# ─── ETS Portal URLs ──────────────────────────────────────────────────────
# ETS Portal main entry point. Defaults to https://see.etsmtl.ca.
ETS_BASE_URL=https://see.etsmtl.ca

# ─── AI Filtering — provider configuration ────────────────────────────────────
# The adapter works with any OpenAI-compatible chat completion API.
# Switch providers by changing AI_PROVIDER (or set AI_BASE_URL explicitly).

# Provider shorthand: gemini | openai | groq | mistral | openrouter | ollama
# Default: gemini
AI_PROVIDER=gemini

# API key for the chosen provider.
AI_API_KEY=your_api_key_here

# Base URL of the OpenAI-compatible endpoint.
# Leave unset to use the provider preset (recommended).
# Preset URLs:
#   gemini    → https://generativelanguage.googleapis.com/v1beta/openai/
#   openai    → https://api.openai.com/v1
#   groq      → https://api.groq.com/openai/v1
#   mistral   → https://api.mistral.ai/v1
#   openrouter→ https://openrouter.ai/api/v1
#   ollama    → http://localhost:11434/v1
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Model name (leave unset to use the provider default).
# Examples:
#   gemini-3.5-flash          (Gemini — balanced, recommended)
#   gemini-3.1-flash-lite-preview  (Gemini — cheapest/fastest)
#   gpt-4o-mini               (OpenAI)
#   llama-3.1-8b-instant      (Groq — free tier available)
#   mistral-small-latest      (Mistral)
# AI_MODEL=gemini-3.5-flash

# Optional Backup AI config
AI_BACKUP_PROVIDER=openai                                   # e.g., groq, openai, mistral, openrouter
AI_BACKUP_API_KEY=xxx.xxx                                   # API key for the backup provider
AI_BACKUP_MODEL=gpt-4o-mini                                 # Model to use on the backup provider

# Max placements sent per API call (default: 10)
# Reduce if hitting context window limits.
AI_BATCH_SIZE=10

# Generation temperature 0–1 (default: 0 = deterministic scoring)
AI_TEMPERATURE=0

# Candidate profile injected into the AI prompt (personalises scoring).
# Example: "Étudiant en génie logiciel à l'ÉTS, spécialisé en backend Node.js,
# intéressé par les stages en développement logiciel à Montréal."
AI_CANDIDATE_PROFILE=Étudiant en génie logiciel à l'ÉTS, intéressé par les stages en développement logiciel.

# Relevance threshold 0–100: placements scoring below this are not notified.
AI_RELEVANCE_THRESHOLD=60

# ─── Local Pre-filtering (Step 1) ──────────────────────────────────────────
# Comma-separated list of allowed locations (case-insensitive substring match).
# If empty, all locations are allowed.
# FILTER_ALLOWED_LOCATIONS=Montréal, Laval, Brossard, Remote, Longueuil, Québec, Joliette

# Comma-separated list of explicitly excluded locations.
# FILTER_EXCLUDED_LOCATIONS=Ontario, France

# Comma-separated list of excluded keywords in job titles.
# FILTER_EXCLUDED_KEYWORDS=QA, Quality Assurance, Testeur, Test

# ─── AI Custom Prompt (Step 2) ─────────────────────────────────────────────
# Custom instructions/rubrics describing what the AI filter should accept and reject.
# AI_CUSTOM_PROMPT=Exclude pure Quality Assurance (QA) or manual testing positions. Prioritize roles focused on backend engineering, Node.js development, and cloud databases.

# ─── Database ──────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file
# The directory will be created automatically on first run.
#
# Uses the built-in node:sqlite module (no native addon, no compilation):
#   - Node 22.5–22.x: requires --experimental-sqlite flag
#   - Node 23+:       stable, no flag required
#   - Node 24 (current): stable ✓
DATABASE_PATH=./data/flexplus.db

# ─── Notifications ─────────────────────────────────────────────────────────
# ─── Discord Bot ────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# ID of the channel where notifications will be posted
DISCORD_CHANNEL_ID=your_channel_id_here

# Optional: Discord Role ID or User ID to ping on important notifications (errors, new offers, interviews)
# e.g., <@123456789> for user or <@&123456789> for role. Leave empty for no ping.
DISCORD_IMPORTANT_TAG=

# Comma-separated list of Discord User IDs that are authorized to use commands (!status, !auth, !help)
# and click buttons (Quick Apply, MFA Ready). If left empty, no security check is performed.
DISCORD_ALLOWED_USERS=

# ─── Scheduler ─────────────────────────────────────────────────────────────
# Cron expression controlling how often the scraper runs.
# Run every 20 minutes from 8:00 AM to 5:59 PM (inclusive), Monday through Friday, to avoid suspicion.
SCRAPER_CRON=*/20 8-17 * * 1-5

# Add a random delay (jitter) in seconds before the automated scraper run triggers to reduce bot detection.
SCRAPER_JITTER_MIN_SEC=0
SCRAPER_JITTER_MAX_SEC=300

# ─── Scraper Behaviour ─────────────────────────────────────────────────────
# Set to "true" to run Playwright in headless mode (recommended for CI)
PLAYWRIGHT_HEADLESS=true

# Set to "true" to automatically submit postulations for high-relevance matches
# WARNING: Extremely risky. Defaults to false.
AUTO_APPLY=false

# Timeout in milliseconds for page navigation actions
PLAYWRIGHT_TIMEOUT_MS=30000

# ─── Logging ───────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Node environment
NODE_ENV=development
