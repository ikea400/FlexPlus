{
  "name": "@flexplus/scraper",
  "version": "0.1.0",
  "description": "Headless microservice that scrapes the ETS Placement Flex portal, AI-filters results, persists to SQLite, and sends email notifications.",
  "type": "module",
  "main": "dist/main.js",
  "_note_sqlite": "SQLite is provided by the built-in node:sqlite module (Node >= 22.5). No native addon required.",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "simple-scrape": "tsx src/simple-scrape-headed.ts",
    "start": "node dist/main.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "openai": "^6.46.0",
    "playwright": "^1.49.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "scraper",
    "playwright",
    "gemini",
    "ets",
    "placement",
    "microservice",
    "ddd",
    "hexagonal"
  ],
  "license": "MIT"
}
